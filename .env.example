# EVARA BNS - Environment Configuration Example
# Copy this file to .env and fill in the required values
# DO NOT commit .env to version control!

# Server Configuration
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URLs
FRONTEND_URL=http://localhost:5000
QR_TARGET_URL=http://localhost:5000/checkin

# API Configuration
APP_URL=http://localhost:5000
API_BASE_URL=/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_REQUESTS=200
PASSWORD_CHANGE_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_CHANGE_RATE_LIMIT_MAX=8
RATE_LIMIT_REDIS_ENABLED=false
REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=evara:rate-limit:
RATE_LIMIT_IPV6_SUBNET=56

# Proxy Configuration
TRUST_PROXY_HOPS=1
REQUEST_LOG_FORMAT=

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Initial Admin User
# This is used on first app startup to create the admin account
INITIAL_ADMIN_FULL_NAME=System Admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=SecurePassword123!

# Attendance Fencing Configuration
# Modes: ip, geo, either, both, off
# - ip: only approved IPs can submit attendance
# - geo: browser location must be inside radius
# - either: approved network OR approved location
# - both: approved network AND approved location
# - off: no restriction
ATTENDANCE_ACCESS_MODE=off
ATTENDANCE_ALLOWED_IPS=
ATTENDANCE_ALLOWED_IP_PREFIXES=
ATTENDANCE_ALLOWED_CIDRS=

# Optional: Geofence settings (for geo mode)
# ATTENDANCE_GEOFENCE_LAT=30.0444
# ATTENDANCE_GEOFENCE_LNG=31.2357
# ATTENDANCE_GEOFENCE_RADIUS_METERS=500
